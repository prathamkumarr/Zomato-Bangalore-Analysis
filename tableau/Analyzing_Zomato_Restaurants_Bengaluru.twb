      <aliases enabled='yes' />
      <column caption='Online Order Label' datatype='string' name='[Calculation_4949333646675970]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [online_order] = 1 THEN &quot;Yes&quot; ELSE &quot;No&quot; END' />
      </column>
      <column caption='Rating_Rank' datatype='integer' name='[Calculation_4949333850374147]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([votes]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Premium_avg_rate' datatype='real' name='[Calculation_4949333867528197]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED : AVG(IF [price_category] = &apos;Premium&apos; THEN [rate] END)}' />
      </column>
      <column caption='Is_Hidden_gem' datatype='boolean' name='[Calculation_4949333867663366]' role='measure' type='nominal'>
        <calculation class='tableau' formula='AVG([rate]) &gt; MIN([Calculation_4949333867528197])' />
      </column>
      <column caption='Online Order Pct' datatype='real' name='[Calculation_4949334678794247]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([online_order]) * 100' />
      </column>
      <column caption='Table Booking Pct' datatype='real' name='[Calculation_4949334679851016]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([book_table]) * 100' />
      </column>
      <column caption='Platform avg rating' datatype='real' name='[Calculation_4949334738587659]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED : AVG([rate])}' />
      </column>
      <column caption='Performance tier' datatype='string' name='[Calculation_4949334739406862]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([rate]) &gt;= AVG([Calculation_4949334738587659]) AND COUNT([name]) &gt;= 100&#10;THEN &quot;Star Performer&quot;&#10;ELSEIF AVG([rate]) &lt; AVG([Calculation_4949334738587659]) AND COUNT([name]) &gt;= 100&#10;THEN &quot;Overrated&quot;&#10;ELSEIF AVG([rate]) &gt;= AVG([Calculation_4949334738587659])&#10;THEN &quot;Hidden Gem&quot;&#10;ELSE &quot;Below Average / Niche&quot;&#10;END' />
      </column>
      <column caption='Top location label' datatype='string' name='[Calculation_4949334767742991]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF RANK(COUNT([name]), &apos;desc&apos;) &lt;= 12&#10;THEN ATTR([location])&#10;ELSE NULL&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Credibility score' datatype='real' name='[Calculation_4949334784487440]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[rate] * LOG([votes], 10)' />
      </column>
      <column caption='Credibility rank' datatype='integer' name='[Calculation_4949334784602129]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Calculation_4949334784487440]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='location_coords.csv' datatype='table' name='[__tableau_internal_object_id__].[location_coords.csv_7B8BACE793D1401494AAC5D976EA136E]' role='measure' type='quantitative' />
      <column caption='restaurants_unique.csv' datatype='table' name='[__tableau_internal_object_id__].[restaurants_unique.csv_949614569BC44A6EA24C4C1C146D7517]' role='measure' type='quantitative' />
