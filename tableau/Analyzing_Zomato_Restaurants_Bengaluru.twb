          </datasources>
          <datasource-dependencies datasource='federated.0k7yjcg0qedto31g51ikk05j1uy4'>
            <column caption='Table Booking Pct' datatype='real' name='[Calculation_4949334679851016]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([book_table]) * 100' />
            </column>
            <column caption='Book Table' datatype='integer' name='[book_table]' role='measure' type='quantitative' />
