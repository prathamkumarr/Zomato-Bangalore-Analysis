        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <text column='[federated.0k7yjcg0qedto31g51ikk05j1uy4].[usr:Calculation_4949334679851016:qk]' />
            </encodings>
            <customized-label>
              <formatted-text>
                <run bold='true' fontcolor='#0433ff' fontname='Tableau Light' fontsize='36'>&lt;</run>
                <run bold='true' fontcolor='#0433ff' fontname='Tableau Light' fontsize='36'>[federated.0k7yjcg0qedto31g51ikk05j1uy4].[usr:Calculation_4949334679851016:qk]</run>
