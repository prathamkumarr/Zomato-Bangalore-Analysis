    <worksheet name='Hidden_gems'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Hidden Gems</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='restaurants_unique' name='federated.0k7yjcg0qedto31g51ikk05j1uy4' />
          </datasources>
          <datasource-dependencies datasource='federated.0k7yjcg0qedto31g51ikk05j1uy4'>
            <column caption='Rating_Rank' datatype='integer' name='[Calculation_4949333850374147]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='RANK(SUM([votes]), &apos;desc&apos;)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Premium_avg_rate' datatype='real' name='[Calculation_4949333867528197]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED : AVG(IF [price_category] = &apos;Premium&apos; THEN [rate] END)}' />
            </column>
            <column caption='Is_Hidden_gem' datatype='boolean' name='[Calculation_4949333867663366]' role='measure' type='nominal'>
              <calculation class='tableau' formula='AVG([rate]) &gt; MIN([Calculation_4949333867528197])' />
            </column>
            <column caption='Approx Cost' datatype='integer' name='[approx_cost]' role='measure' type='quantitative' />
            <column-instance column='[approx_cost]' derivation='Avg' name='[avg:approx_cost:qk]' pivot='key' type='quantitative' />
            <column-instance column='[rate]' derivation='Avg' name='[avg:rate:qk]' pivot='key' type='quantitative' />
            <column-instance column='[votes]' derivation='Avg' name='[avg:votes:qk]' pivot='key' type='quantitative' />
            <column caption='Location' datatype='string' name='[location]' role='dimension' type='nominal' />
            <column caption='Name' datatype='string' name='[name]' role='dimension' type='nominal' />
            <column-instance column='[location]' derivation='None' name='[none:location:nk]' pivot='key' type='nominal' />
            <column-instance column='[name]' derivation='None' name='[none:name:nk]' pivot='key' type='nominal' />
            <column-instance column='[price_category]' derivation='None' name='[none:price_category:nk]' pivot='key' type='nominal' />
            <column caption='Price Category' datatype='string' name='[price_category]' role='dimension' type='nominal' />
            <column caption='Rate' datatype='real' name='[rate]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_4949333850374147]' derivation='User' name='[usr:Calculation_4949333850374147:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Columns' />
            </column-instance>
            <column-instance column='[Calculation_4949333867663366]' derivation='User' name='[usr:Calculation_4949333867663366:nk]' pivot='key' type='nominal' />
            <column caption='Votes' datatype='integer' name='[votes]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <filter class='quantitative' column='[federated.0k7yjcg0qedto31g51ikk05j1uy4].[avg:votes:qk]' included-values='in-range'>
            <min>500.0</min>
          </filter>
          <computed-sort column='[federated.0k7yjcg0qedto31g51ikk05j1uy4].[none:location:nk]' direction='DESC' using='[federated.0k7yjcg0qedto31g51ikk05j1uy4].[avg:rate:qk]' />
          <computed-sort column='[federated.0k7yjcg0qedto31g51ikk05j1uy4].[none:name:nk]' direction='DESC' using='[federated.0k7yjcg0qedto31g51ikk05j1uy4].[avg:rate:qk]' />
          <filter class='categorical' column='[federated.0k7yjcg0qedto31g51ikk05j1uy4].[none:price_category:nk]'>
            <groupfilter function='member' level='[none:price_category:nk]' member='&quot;Budget&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <filter class='quantitative' column='[federated.0k7yjcg0qedto31g51ikk05j1uy4].[usr:Calculation_4949333850374147:qk]' included-values='in-range'>
            <max>15</max>
          </filter>
          <filter class='categorical' column='[federated.0k7yjcg0qedto31g51ikk05j1uy4].[usr:Calculation_4949333867663366:nk]'>
            <groupfilter function='member' level='[usr:Calculation_4949333867663366:nk]' member='true' user:ui-domain='relevant' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.0k7yjcg0qedto31g51ikk05j1uy4].[none:price_category:nk]</column>
            <column>[federated.0k7yjcg0qedto31g51ikk05j1uy4].[avg:votes:qk]</column>
            <column>[federated.0k7yjcg0qedto31g51ikk05j1uy4].[usr:Calculation_4949333867663366:nk]</column>
            <column>[federated.0k7yjcg0qedto31g51ikk05j1uy4].[usr:Calculation_4949333850374147:qk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <encoding attr='space' class='0' domain-expand='false' field='[federated.0k7yjcg0qedto31g51ikk05j1uy4].[avg:rate:qk]' field-type='quantitative' scope='cols' type='space' />
